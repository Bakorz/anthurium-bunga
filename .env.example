# ============================================================
# Environment Variables for Vercel Serverless Function
# --------------------------------------------------------
# These are read by api/metabase/embed-url.js at runtime.
#
# FOR LOCAL DEVELOPMENT (vercel dev):
#   Create a .env file in the project root. Vercel CLI will
#   automatically load it when running `vercel dev`.
#
# FOR PRODUCTION (Vercel Dashboard):
#   Set these in: Vercel Dashboard > Project > Settings >
#   Environment Variables
#
#   Do NOT put secrets in this file — it's tracked in git.
#   This is just a template. Copy it to .env and fill in values.
# ============================================================

METABASE_SITE_URL=https://metabase.cronous.my.id
METABASE_SECRET_KEY=your_metabase_secret_key_here
DASHBOARD_ID=3